# Floria Garden — ortam değişkenleri
# Vercel → Settings → Environment Variables içine girilir (koda yazılmaz).

# Site adresi (SEO/sitemap için)
NEXT_PUBLIC_SITE_URL=https://gemlikfloriagarden.com

# Yönetim ve oturum güvenliği
ADMIN_PASSWORD=buraya-guclu-yonetici-sifresi
ADMIN_SECRET=buraya-en-az-32-karakterlik-gizli-anahtar
MEMBER_SECRET=buraya-farkli-en-az-32-karakterlik-gizli-anahtar

# Bakım modu (1 yaparsan public site kapatılır, yönetim paneli açık kalır)
NEXT_PUBLIC_MAINTENANCE=0

# cPanel MySQL bağlantısı
DB_HOST=5.2.85.51
DB_PORT=3306
DB_USER=gemlikfl_floria
DB_PASSWORD=buraya-cpanel-db-sifresi
DB_NAME=gemlikfl_floria
DB_CONNECTION_LIMIT=3

# Sipariş e-posta bildirimi (opsiyonel ama canlıda önerilir)
SMTP_HOST=smtp.ornek.com
SMTP_PORT=587
SMTP_USER=bildirim@gemlikfloriagarden.com
SMTP_PASS=buraya-smtp-sifresi
ORDER_NOTIFY_EMAIL=merhaba@gemlikfloriagarden.com
